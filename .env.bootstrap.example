# WorkerOps deploy config — copy to .env.bootstrap and fill in.
# Used by ./WorkerOps_manual_deploy.sh <develop|prod>. (Never commit .env.bootstrap.)

# Cloudflare API token: Workers Scripts:Edit + Workers KV Storage:Edit + Zone:Read + DNS:Edit
WORKEROPS_DIRECT_DEPLOY_CF_API_TOKEN=replace-with-token

# Cloudflare account id (32-char lowercase hex)
WORKEROPS_CF_ACCOUNT_ID=replace-with-account-id

# Public URL WorkerOps fronts (route target).
#   develop/test: a test hostname on a zone you control
#   prod        : the app's public URL
WORKEROPS_DEPLOY_URL=https://workerops-test.kuro.boo/

# Ops console / endpoint token (stored as the WORKER_OPS_TOKEN secret)
WORKER_OPS_TOKEN=replace-with-a-strong-random-token

# ── Optional overrides ──────────────────────────────────────────────────────
# WORKEROPS_CF_ZONE_NAME=kuro.boo
# WORKEROPS_WORKER_NAME=workerops-develop
# WORKEROPS_KV_NS_NAME=workerops-state-develop
